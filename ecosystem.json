{
  "apps": [
    {
      "name": "ai-support-backend",
      "cwd": "./backend",
      "script": "bash",
      "args": "-lc \"uv run uvicorn app.main:app --host 0.0.0.0 --port 8000\"",
      "interpreter": "none",
      "env": {
        "PYTHONPATH": "."
      }
    },
    {
      "name": "ai-support-frontend",
      "cwd": "./frontend",
      "script": "npm",
      "args": "run preview -- --host 0.0.0.0 --port 5173",
      "interpreter": "none",
      "env": {
        "NODE_ENV": "production"
      }
    }
  ]
}
